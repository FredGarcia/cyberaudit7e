>> "README.md" echo( 
>> "README.md" echo( ^| Plage ^| Evaluation ^| Couleur ^|
>> "README.md" echo( ^|-------^|-----------^|---------^|
>> "README.md" echo( ^| ^>= 0.70 (70%%) ^| Bon -- conforme ou en bonne voie ^| Vert ^|
>> "README.md" echo( ^| 0.40 -- 0.69 ^| A ameliorer -- corrections necessaires ^| Orange ^|
>> "README.md" echo( ^| ^< 0.40 (40%%) ^| Critique -- non-conformite majeure ^| Rouge ^|
